generator client {
  provider = "prisma-client-js"
}

// PostgreSQL only — no SQLite/MongoDB. DATABASE_URL in backend/.env
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum IotSource {
  rfid
  sensor
  qr_scan
  webhook
  manual
}

enum ReorderStatus {
  pending
  ordered
  dismissed
}

model User {
  id           String   @id @default(uuid())
  googleId     String?  @unique @map("google_id")
  email        String   @unique
  passwordHash String?  @map("password_hash")
  role         UserRole @default(user)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  items       Item[]

  @@map("categories")
}

model WarehouseZone {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  items       Item[]

  @@map("warehouse_zones")
}

model Item {
  id               String   @id @default(uuid())
  sku              String   @unique
  name             String
  description      String?
  categoryId       String?  @map("category_id")
  category         Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  zoneId           String?  @map("zone_id")
  zone             WarehouseZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  binCode          String?  @map("bin_code")
  unit             String   @default("pcs")
  reorderLevel     Int      @default(0) @map("reorder_level")
  currentQuantity  Decimal  @default(0) @map("current_quantity") @db.Decimal(12, 2)
  unitCost         Decimal? @map("unit_cost") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  movements        StockMovement[]
  forecasts        DemandForecast[]
  iotEvents        IotEvent[]
  reorderSuggestions ReorderSuggestion[]

  @@index([categoryId])
  @@index([zoneId])
  @@index([name])
  @@map("items")
}

model IotEvent {
  id            String    @id @default(uuid())
  itemId        String    @map("item_id")
  item          Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  source        IotSource
  eventType     String    @map("event_type")
  message       String?
  quantityDelta Decimal?  @map("quantity_delta") @db.Decimal(12, 2)
  metadata      Json      @default("{}")
  occurredAt    DateTime  @default(now()) @map("occurred_at")

  @@index([itemId, occurredAt])
  @@map("iot_events")
}

model ReorderSuggestion {
  id           String        @id @default(uuid())
  itemId       String        @map("item_id")
  item         Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  suggestedQty Int           @map("suggested_qty")
  reason       String
  status       ReorderStatus @default(pending)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@map("reorder_suggestions")
}

model StockMovement {
  id         String   @id @default(uuid())
  itemId     String   @map("item_id")
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  delta      Decimal  @db.Decimal(12, 2)
  reason     String?
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([itemId, occurredAt])
  @@map("stock_movements")
}

model DemandForecast {
  id           String   @id @default(uuid())
  itemId       String   @map("item_id")
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  horizonDays  Int      @map("horizon_days")
  model        String
  predictions  Json     @map("predictions")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([itemId])
  @@map("demand_forecasts")
}
