# =============================================================================
# DATABASE — PostgreSQL only (required)
# =============================================================================
# Prisma is configured for PostgreSQL only (backend/prisma/schema.prisma).
# Create an empty database first, e.g. named "inventory", then set URL below.
#
# Docker Compose (user/password/db = inventory):
#   DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"
#
# Typical Windows install (default superuser "postgres"):
#   DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/inventory?schema=public"
#
# Cloud (Neon, Supabase, Railway, etc.): paste the connection string they provide.
# =============================================================================

PORT=4000
DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
WEB_ORIGIN="http://localhost:5173"
GOOGLE_CLIENT_ID=

# Forecast: point API at FastAPI ML service (same value as docker-compose ML_INTERNAL_KEY).
# Leave empty to use in-process forecast (no Python).
ML_SERVICE_URL=http://localhost:8001
ML_INTERNAL_KEY=dev-ml-key-change-me

# Chat assistant (OpenAI-compatible API). Leave key empty to use rule-based fallback.
# Groq free-tier preset (recommended for development):
# - Create API key: https://console.groq.com/keys
# - Paste key in OPENAI_API_KEY below
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.1-8b-instant
OPENAI_BASE_URL=https://api.groq.com/openai/v1
